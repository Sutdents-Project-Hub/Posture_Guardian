# Server-side names only. Keep real values in an ignored .env or deployment secret store.
APP_ENV=development
# Local zero-setup default is SQLite. The separate Coolify PostgreSQL Resource
# supplies the DB_* fields at runtime; SQLAlchemy safely encodes password characters.
DATABASE_URL=sqlite+aiosqlite:///./posture_guardian.db
DB_HOST=
DB_PORT=5432
DB_NAME=posture_guardian
DB_USER=posture_guardian
DB_PASSWORD=
CORS_ORIGINS=http://localhost:8081,http://127.0.0.1:8081,http://localhost:19006,http://127.0.0.1:19006
# Pinned official MediaPipe Pose Landmarker Full float16/1 model.
POSE_MODEL_PATH=./models/pose_landmarker_full.task
MIGRATION_ROOT=.
AI_PROVIDER=fallback
AI_BASE_URL=
AI_API_KEY=
# 已以量界智算測試帳號驗證的 OpenAI-compatible model；只有設定 runtime secret 時才改 AI_PROVIDER=liangjie。
AI_MODEL=gpt-4o-mini
AI_API_MODE=chat_completions
AI_TIMEOUT_SECONDS=8
# Opaque bearer sessions expire after this many days. Keep production values within 1–30.
AUTH_SESSION_DAYS=14
