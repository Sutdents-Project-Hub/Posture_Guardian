# Server-side names only. Keep real values in an ignored .env or deployment secret store.
APP_ENV=development
# Local zero-setup default is SQLite. Coolify uses the separate DB_* fields so
# reserved password characters are encoded safely by SQLAlchemy.
DATABASE_URL=sqlite+aiosqlite:///./posture_guardian.db
DB_HOST=
DB_PORT=5432
DB_NAME=posture_guardian
DB_USER=posture_guardian
DB_PASSWORD=
CORS_ORIGINS=http://localhost:8081,http://127.0.0.1:8081,http://localhost:19006,http://127.0.0.1:19006
POSE_MODEL_PATH=./models/pose_landmarker_lite.task
MIGRATION_ROOT=.
AI_PROVIDER=fallback
AI_BASE_URL=
AI_API_KEY=
AI_MODEL=
AI_API_MODE=chat_completions
AI_TIMEOUT_SECONDS=8
